{
  "watch": [
    "server.js",
    "config",
    "controllers",
    "middleware",
    "models",
    "routes",
    "services",
    "utils"
  ],
  "ext": "js,json",
  "ignore": [
    "node_modules/",
    ".git/",
    "frontend/",
    "*.log",
    ".DS_Store"
  ],
  "delay": 500,
  "verbose": true,
  "env": {
    "NODE_ENV": "development"
  }
}
